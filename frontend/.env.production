# Production environment
# Override VITE_API_BASE_URL at build time if frontend and backend are on different domains.
# Leave empty if served from the same origin (Nginx proxy) or set via CI env var.
VITE_API_BASE_URL=
VITE_APP_TITLE=Enterprise Asset Management System
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_REPORTS=true
VITE_FEATURE_DOCUMENTS=true
VITE_FEATURE_ANALYTICS=false
